<div class="space-y-8">
  <div class="flex flex-col gap-6 lg:flex-row lg:items-center lg:justify-between">
    <div>
      <p class="text-xs uppercase tracking-[0.3em] text-slate-400">Workouts</p>
      <h1 class="fittrack-display text-3xl text-slate-900 sm:text-4xl">Plan, track, and complete</h1>
      <p class="text-sm text-slate-500">Keep momentum with upcoming sessions and review past work.</p>
    </div>
    <div class="flex flex-wrap items-center gap-3">
      <%= link_to "New workout", new_workout_path, class: "btn btn-primary" %>
      <%= link_to "AI workout", ai_path, class: "btn btn-outline border-slate-200 bg-white/80" %>
    </div>
  </div>

  <div class="grid grid-cols-1 gap-6 lg:grid-cols-2">
    <div class="fittrack-surface rounded-3xl">
      <div class="border-b border-slate-200/60 px-6 py-5">
        <h2 class="text-lg font-semibold text-slate-900">Upcoming</h2>
        <p class="text-xs text-slate-500">Scheduled sessions you can still adjust.</p>
      </div>
      <% if @upcoming.any? %>
        <ul class="divide-y divide-slate-200/60">
          <% @upcoming.each do |workout| %>
            <li class="px-6 py-4">
              <div class="flex flex-wrap items-center justify-between gap-3">
                <div>
                  <p class="text-sm font-semibold text-slate-900">
                    <%= link_to workout.name, workout, class: "hover:text-slate-700" %>
                  </p>
                  <p class="mt-1 text-xs text-slate-500"><%= workout.scheduled_date.strftime("%b %d, %Y") %> · <%= workout.exercises.count %> exercises</p>
                </div>
                <span class="fittrack-pill <%= workout.ai_generated? ? 'bg-sky-100 text-sky-700' : 'bg-slate-100 text-slate-600' %>">
                  <%= workout.ai_generated? ? "AI" : "Manual" %>
                </span>
              </div>
            </li>
          <% end %>
        </ul>
      <% else %>
        <div class="px-6 py-10 text-center text-sm text-slate-500">No upcoming workouts scheduled.</div>
      <% end %>
    </div>

    <div class="fittrack-surface rounded-3xl">
      <div class="border-b border-slate-200/60 px-6 py-5">
        <h2 class="text-lg font-semibold text-slate-900">Past</h2>
        <p class="text-xs text-slate-500">Review your completed and pending sessions.</p>
      </div>
      <% if @past.any? %>
        <ul class="divide-y divide-slate-200/60">
          <% @past.each do |workout| %>
            <li class="px-6 py-4">
              <div class="flex flex-wrap items-center justify-between gap-3">
                <div>
                  <p class="text-sm font-semibold text-slate-900">
                    <%= link_to workout.name, workout, class: "hover:text-slate-700" %>
                  </p>
                  <p class="mt-1 text-xs text-slate-500"><%= workout.scheduled_date.strftime("%b %d, %Y") %> · <%= workout.exercises.count %> exercises</p>
                </div>
                <span class="fittrack-pill <%= workout.completed? ? 'bg-emerald-100 text-emerald-700' : 'bg-amber-100 text-amber-700' %>">
                  <%= workout.completed? ? "Completed" : "Pending" %>
                </span>
              </div>
            </li>
          <% end %>
        </ul>
      <% else %>
        <div class="px-6 py-10 text-center text-sm text-slate-500">No past workouts yet.</div>
      <% end %>
    </div>
  </div>
</div>
