<div class="space-y-6">
  <div class="flex flex-col gap-4 sm:flex-row sm:items-start sm:justify-between">
    <div>
      <h1 class="text-2xl font-bold text-gray-900"><%= @workout.name %></h1>
      <p class="mt-1 text-sm text-gray-500"><%= @workout.scheduled_date.strftime("%B %d, %Y") %> · <%= @workout.duration_minutes || "~30" %> min</p>
      <% if @workout.completed? %>
        <span class="mt-2 inline-flex items-center rounded-full bg-green-50 px-2 py-1 text-xs font-medium text-green-700">Completed</span>
      <% end %>
    </div>
    <div class="flex items-center gap-2">
      <% unless @workout.completed? %>
        <%= button_to "Mark Complete", complete_workout_path(@workout), method: :patch, class: "rounded-md bg-green-600 px-3 py-2 text-sm font-semibold text-white shadow-sm hover:bg-green-500" %>
      <% end %>
      <%= link_to "Edit", edit_workout_path(@workout), class: "rounded-md bg-white px-3 py-2 text-sm font-semibold text-gray-700 shadow-sm ring-1 ring-inset ring-gray-300 hover:bg-gray-50" %>
      <%= button_to "Delete", workout_path(@workout), method: :delete, data: { turbo_confirm: "Delete this workout?" }, class: "rounded-md bg-white px-3 py-2 text-sm font-semibold text-red-600 shadow-sm ring-1 ring-inset ring-red-200 hover:bg-red-50" %>
    </div>
  </div>

  <div class="grid grid-cols-1 gap-6 lg:grid-cols-3">
    <div class="lg:col-span-2 space-y-4">
      <div class="rounded-lg bg-white shadow">
        <div class="border-b border-gray-200 px-4 py-3">
          <h2 class="text-sm font-semibold text-gray-900">Exercises</h2>
        </div>
        <% if @workout_exercises.any? %>
          <ul role="list" class="divide-y divide-gray-200">
            <% @workout_exercises.each do |we| %>
              <li class="p-4">
                <div class="flex items-center justify-between">
                  <div>
                    <p class="text-sm font-semibold text-gray-900"><%= we.exercise.name %></p>
                    <p class="mt-1 text-xs text-gray-500">
                      <%= [we.sets && "#{we.sets} sets", we.reps && "#{we.reps} reps", we.duration_seconds && "#{we.duration_seconds}s", we.rest_seconds && "#{we.rest_seconds}s rest"].compact.join(" · ") %>
                    </p>
                  </div>
                  <div class="flex items-center gap-2">
                    <%= button_to "Remove", workout_workout_exercise_path(@workout, we), method: :delete, data: { turbo_confirm: "Remove this exercise?" }, class: "text-xs font-semibold text-red-600 hover:text-red-700" %>
                  </div>
                </div>
              </li>
            <% end %>
          </ul>
        <% else %>
          <div class="p-6 text-sm text-gray-500">No exercises added yet.</div>
        <% end %>
      </div>

      <% if @workout.notes.present? %>
        <div class="rounded-lg bg-white p-4 shadow">
          <h2 class="text-sm font-semibold text-gray-900">Notes</h2>
          <p class="mt-2 text-sm text-gray-700"><%= simple_format(@workout.notes) %></p>
        </div>
      <% end %>
    </div>

    <div class="space-y-4">
      <div class="rounded-lg bg-white p-4 shadow">
        <h2 class="text-sm font-semibold text-gray-900">Add Exercise</h2>
        <%= form_with model: [@workout, WorkoutExercise.new], local: true, class: "mt-4 space-y-3" do |f| %>
          <div>
            <%= f.label :exercise_id, "Exercise", class: "block text-sm font-medium text-gray-700" %>
            <%= f.collection_select :exercise_id, @exercises, :id, :name, { prompt: "Select" }, class: "mt-1 block w-full rounded-md border-gray-300 shadow-sm focus:border-indigo-500 focus:ring-indigo-500 sm:text-sm" %>
          </div>
          <div class="grid grid-cols-2 gap-2">
            <div>
              <%= f.label :sets, class: "block text-xs font-medium text-gray-700" %>
              <%= f.number_field :sets, min: 1, class: "mt-1 block w-full rounded-md border-gray-300 shadow-sm focus:border-indigo-500 focus:ring-indigo-500 sm:text-sm" %>
            </div>
            <div>
              <%= f.label :reps, class: "block text-xs font-medium text-gray-700" %>
              <%= f.number_field :reps, min: 1, class: "mt-1 block w-full rounded-md border-gray-300 shadow-sm focus:border-indigo-500 focus:ring-indigo-500 sm:text-sm" %>
            </div>
            <div>
              <%= f.label :duration_seconds, "Duration (s)", class: "block text-xs font-medium text-gray-700" %>
              <%= f.number_field :duration_seconds, min: 0, class: "mt-1 block w-full rounded-md border-gray-300 shadow-sm focus:border-indigo-500 focus:ring-indigo-500 sm:text-sm" %>
            </div>
            <div>
              <%= f.label :rest_seconds, "Rest (s)", class: "block text-xs font-medium text-gray-700" %>
              <%= f.number_field :rest_seconds, min: 0, class: "mt-1 block w-full rounded-md border-gray-300 shadow-sm focus:border-indigo-500 focus:ring-indigo-500 sm:text-sm" %>
            </div>
          </div>
          <%= f.submit "Add", class: "w-full rounded-md bg-indigo-600 px-3 py-2 text-sm font-semibold text-white shadow-sm hover:bg-indigo-500" %>
        <% end %>
      </div>

      <div class="rounded-lg bg-white p-4 shadow">
        <h2 class="text-sm font-semibold text-gray-900">Summary</h2>
        <dl class="mt-3 space-y-2 text-sm text-gray-700">
          <div class="flex items-center justify-between">
            <dt>Exercises</dt>
            <dd><%= @workout_exercises.count %></dd>
          </div>
          <div class="flex items-center justify-between">
            <dt>Estimated calories</dt>
            <dd><%= @workout.estimated_calories %></dd>
          </div>
        </dl>
      </div>
    </div>
  </div>
</div>
