<div class="space-y-6">
  <div class="flex items-center justify-between">
    <div>
      <h1 class="text-2xl font-bold text-gray-900">Edit Workout</h1>
      <p class="text-sm text-gray-500">Update workout details.</p>
    </div>
    <%= link_to "Back", workout_path(@workout), class: "text-sm font-medium text-indigo-600 hover:text-indigo-500" %>
  </div>

  <div class="rounded-lg bg-white p-6 shadow">
    <%= render "form", workout: @workout %>
  </div>
</div>
