<div class="space-y-6">
  <div class="flex flex-col gap-4 sm:flex-row sm:items-center sm:justify-between">
    <div>
      <h1 class="text-2xl font-bold text-gray-900">Foods</h1>
      <p class="text-sm text-gray-500">Your nutrition database for faster meal logging.</p>
    </div>
    <div class="flex items-center gap-3">
      <%= link_to "Add Food", new_food_path, class: "rounded-md bg-indigo-600 px-4 py-2 text-sm font-semibold text-white shadow-sm hover:bg-indigo-500" %>
      <%= link_to "Nutrition Dashboard", nutrition_path, class: "rounded-md bg-white px-4 py-2 text-sm font-semibold text-indigo-600 shadow-sm ring-1 ring-inset ring-indigo-300 hover:bg-indigo-50" %>
    </div>
  </div>

  <div class="rounded-lg bg-white p-4 shadow">
    <%= form_with url: foods_path, method: :get, local: true, class: "flex flex-col gap-3 sm:flex-row sm:items-end" do |f| %>
      <div class="flex-1">
        <%= f.label :q, "Search", class: "block text-sm font-medium text-gray-700" %>
        <%= f.text_field :q, value: params[:q], placeholder: "e.g. Greek yogurt", class: "mt-1 block w-full rounded-md border-gray-300 shadow-sm focus:border-indigo-500 focus:ring-indigo-500 sm:text-sm" %>
      </div>
      <%= f.submit "Search", class: "rounded-md bg-indigo-600 px-4 py-2 text-sm font-semibold text-white shadow-sm hover:bg-indigo-500" %>
    <% end %>
  </div>

  <div class="overflow-hidden rounded-lg bg-white shadow">
    <% if @foods.any? %>
      <ul role="list" class="divide-y divide-gray-200">
        <% @foods.each do |food| %>
          <li class="p-4 sm:p-6">
            <div class="flex flex-col gap-2 sm:flex-row sm:items-center sm:justify-between">
              <div>
                <h2 class="text-lg font-semibold text-gray-900"><%= link_to food.name, food_path(food), class: "hover:text-indigo-600" %></h2>
                <p class="mt-1 text-sm text-gray-500">
                  <%= [food.brand.presence, "#{food.serving_size} #{food.serving_unit}".strip.presence].compact.join(" · ") %>
                </p>
              </div>
              <div class="text-sm text-gray-600"><%= food.calories %> cal · <%= food.macros_summary %></div>
            </div>
          </li>
        <% end %>
      </ul>
    <% else %>
      <div class="p-6 text-sm text-gray-500">No foods found. Try a different search or add a new food.</div>
    <% end %>
  </div>
</div>
