<%= form_with model: meal_plan, local: true, class: "space-y-6" do |f| %>
  <div class="form-control">
    <%= f.label :week_start_date, "Week starting", class: "label text-sm font-semibold text-slate-700" %>
    <%= f.date_field :week_start_date, class: "input input-bordered w-full bg-white/80" %>
  </div>

  <div class="form-control">
    <%= f.label :notes, class: "label text-sm font-semibold text-slate-700" %>
    <%= f.text_area :notes, rows: 3, class: "textarea textarea-bordered w-full bg-white/80" %>
  </div>

  <label class="flex items-center gap-2 text-sm font-semibold text-slate-600">
    <%= f.check_box :ai_generated, class: "checkbox checkbox-primary" %>
    AI generated
  </label>

  <div class="rounded-2xl border border-slate-200/60 bg-white/70">
    <div class="border-b border-slate-200/60 px-4 py-2 text-sm font-semibold text-slate-900">Plan by day</div>
    <div class="divide-y divide-slate-200/60">
      <% meal_plan.meal_plan_days.sort_by(&:day_of_week).each do |day| %>
        <%= f.fields_for :meal_plan_days, day do |df| %>
          <div class="p-4">
            <div class="text-sm font-semibold text-gray-900"><%= day.day_name %></div>
            <div class="mt-3 grid grid-cols-1 gap-3 md:grid-cols-3">
              <div class="form-control">
                <%= df.label :breakfast_recipe_id, "Breakfast", class: "label text-xs font-semibold text-slate-600" %>
                <%= df.collection_select :breakfast_recipe_id, @recipes, :id, :name, { include_blank: true }, class: "select select-bordered w-full bg-white/80" %>
              </div>
              <div class="form-control">
                <%= df.label :lunch_recipe_id, "Lunch", class: "label text-xs font-semibold text-slate-600" %>
                <%= df.collection_select :lunch_recipe_id, @recipes, :id, :name, { include_blank: true }, class: "select select-bordered w-full bg-white/80" %>
              </div>
              <div class="form-control">
                <%= df.label :dinner_recipe_id, "Dinner", class: "label text-xs font-semibold text-slate-600" %>
                <%= df.collection_select :dinner_recipe_id, @recipes, :id, :name, { include_blank: true }, class: "select select-bordered w-full bg-white/80" %>
              </div>
            </div>
            <div class="mt-3 form-control">
              <%= df.label :snacks, class: "label text-xs font-semibold text-slate-600" %>
              <%= df.text_area :snacks, rows: 2, class: "textarea textarea-bordered w-full bg-white/80" %>
            </div>
          </div>
        <% end %>
      <% end %>
    </div>
  </div>

  <div class="flex items-center justify-end">
    <%= f.submit class: "btn btn-primary" %>
  </div>
<% end %>
