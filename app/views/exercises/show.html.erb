<div class="space-y-6">
  <div class="flex items-start justify-between">
    <div>
      <h1 class="text-2xl font-bold text-gray-900"><%= @exercise.name %></h1>
      <p class="mt-1 text-sm text-gray-500"><%= [@exercise.category&.titleize, @exercise.muscle_group&.titleize, @exercise.difficulty&.titleize].compact.join(" · ") %></p>
    </div>
    <%= link_to "Back to exercises", exercises_path, class: "text-sm font-medium text-indigo-600 hover:text-indigo-500" %>
  </div>

  <div class="rounded-lg bg-white p-6 shadow">
    <dl class="grid grid-cols-1 gap-4 sm:grid-cols-2">
      <div>
        <dt class="text-sm font-medium text-gray-500">Equipment</dt>
        <dd class="mt-1 text-sm text-gray-900"><%= @exercise.equipment_needed.presence || "Bodyweight" %></dd>
      </div>
      <div>
        <dt class="text-sm font-medium text-gray-500">Calories / minute</dt>
        <dd class="mt-1 text-sm text-gray-900"><%= @exercise.calories_per_minute || 5 %></dd>
      </div>
    </dl>

    <% if @exercise.description.present? %>
      <div class="mt-6">
        <h2 class="text-sm font-semibold text-gray-900">Description</h2>
        <p class="mt-2 text-sm text-gray-700"><%= simple_format(@exercise.description) %></p>
      </div>
    <% end %>

    <% if @exercise.instructions.present? %>
      <div class="mt-6">
        <h2 class="text-sm font-semibold text-gray-900">Instructions</h2>
        <p class="mt-2 text-sm text-gray-700"><%= simple_format(@exercise.instructions) %></p>
      </div>
    <% end %>
  </div>
</div>
