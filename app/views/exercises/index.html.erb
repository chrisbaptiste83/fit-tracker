<div class="space-y-6">
  <div class="flex flex-col gap-4 sm:flex-row sm:items-center sm:justify-between">
    <div>
      <h1 class="text-2xl font-bold text-gray-900">Exercises</h1>
      <p class="text-sm text-gray-500">Browse and filter exercises by category, muscle group, and difficulty.</p>
    </div>
  </div>

  <div class="rounded-lg bg-white p-4 shadow">
    <%= form_with url: exercises_path, method: :get, local: true, class: "grid grid-cols-1 gap-4 md:grid-cols-4" do |f| %>
      <div>
        <%= f.label :q, "Search", class: "block text-sm font-medium text-gray-700" %>
        <%= f.text_field :q, value: params[:q], placeholder: "e.g. Squat", class: "mt-1 block w-full rounded-md border-gray-300 shadow-sm focus:border-indigo-500 focus:ring-indigo-500 sm:text-sm" %>
      </div>
      <div>
        <%= f.label :category, "Category", class: "block text-sm font-medium text-gray-700" %>
        <%= f.select :category, options_for_select([["All", ""]] + Exercise.categories.keys.map { |c| [c.titleize, c] }, params[:category]), {}, class: "mt-1 block w-full rounded-md border-gray-300 shadow-sm focus:border-indigo-500 focus:ring-indigo-500 sm:text-sm" %>
      </div>
      <div>
        <%= f.label :muscle_group, "Muscle Group", class: "block text-sm font-medium text-gray-700" %>
        <%= f.select :muscle_group, options_for_select([["All", ""]] + Exercise.muscle_groups.keys.map { |m| [m.titleize, m] }, params[:muscle_group]), {}, class: "mt-1 block w-full rounded-md border-gray-300 shadow-sm focus:border-indigo-500 focus:ring-indigo-500 sm:text-sm" %>
      </div>
      <div>
        <%= f.label :difficulty, "Difficulty", class: "block text-sm font-medium text-gray-700" %>
        <%= f.select :difficulty, options_for_select([["All", ""]] + Exercise.difficulties.keys.map { |d| [d.titleize, d] }, params[:difficulty]), {}, class: "mt-1 block w-full rounded-md border-gray-300 shadow-sm focus:border-indigo-500 focus:ring-indigo-500 sm:text-sm" %>
      </div>
      <div class="md:col-span-4 flex items-center justify-between">
        <div class="text-sm text-gray-500"><%= pluralize(@exercises.size, "exercise") %></div>
        <%= f.submit "Apply Filters", class: "rounded-md bg-indigo-600 px-4 py-2 text-sm font-semibold text-white shadow-sm hover:bg-indigo-500" %>
      </div>
    <% end %>
  </div>

  <div class="overflow-hidden rounded-lg bg-white shadow">
    <ul role="list" class="divide-y divide-gray-200">
      <% @exercises.each do |exercise| %>
        <li class="p-4 sm:p-6">
          <div class="flex items-center justify-between">
            <div>
              <h3 class="text-lg font-semibold text-gray-900"><%= link_to exercise.name, exercise_path(exercise), class: "hover:text-indigo-600" %></h3>
              <p class="mt-1 text-sm text-gray-500"><%= [exercise.category&.titleize, exercise.muscle_group&.titleize, exercise.difficulty&.titleize].compact.join(" · ") %></p>
            </div>
            <div class="text-sm text-gray-500">~ <%= exercise.calories_per_minute || 5 %> cal/min</div>
          </div>
          <% if exercise.description.present? %>
            <p class="mt-3 text-sm text-gray-600"><%= truncate(exercise.description, length: 160) %></p>
          <% end %>
        </li>
      <% end %>
    </ul>
  </div>
</div>
