<div class="space-y-8 fittrack-fade-up">
  <div class="flex flex-col gap-6 lg:flex-row lg:items-center lg:justify-between">
    <div class="space-y-2">
      <p class="text-xs uppercase tracking-[0.3em] text-slate-400">Overview</p>
      <h2 class="fittrack-display text-3xl text-slate-900 sm:text-4xl">
        Welcome back<%= current_user.email_address.split('@').first ? ", #{current_user.email_address.split('@').first.capitalize}" : "" %>!
      </h2>
      <p class="text-sm text-slate-500"><%= Date.current.strftime("%A, %B %d, %Y") %></p>
    </div>
    <div class="flex flex-wrap items-center gap-3">
      <%= link_to new_workout_path, class: "btn btn-primary" do %>
        New workout
      <% end %>
      <%= link_to new_meal_path, class: "btn btn-outline border-slate-200 bg-white/80" do %>
        Log meal
      <% end %>
    </div>
  </div>

  <div class="grid grid-cols-1 gap-5 lg:grid-cols-4">
    <div class="fittrack-panel rounded-2xl p-5">
      <p class="text-xs uppercase tracking-[0.2em] text-slate-400">Calories today</p>
      <div class="mt-3 flex items-end gap-2">
        <p class="text-3xl font-semibold text-slate-900"><%= number_with_delimiter(@today_nutrition[:calories]) %></p>
        <p class="text-sm text-slate-500">/ <%= number_with_delimiter(current_user.daily_calorie_goal || current_user.tdee || 2000) %></p>
      </div>
      <% remaining = (current_user.daily_calorie_goal || current_user.tdee || 2000) - @today_nutrition[:calories] %>
      <p class="mt-2 text-sm <%= remaining > 0 ? 'text-emerald-600' : 'text-amber-600' %>">
        <%= remaining > 0 ? "#{number_with_delimiter(remaining)} remaining" : "#{number_with_delimiter(remaining.abs)} over" %>
      </p>
    </div>

    <div class="fittrack-panel rounded-2xl p-5">
      <p class="text-xs uppercase tracking-[0.2em] text-slate-400">Protein</p>
      <div class="mt-3 flex items-end gap-2">
        <p class="text-3xl font-semibold text-slate-900"><%= @today_nutrition[:protein].round(1) %>g</p>
        <p class="text-sm text-slate-500">/ <%= current_user.protein_goal || 150 %>g</p>
      </div>
      <progress class="progress progress-info mt-3" value="<%= [(@today_nutrition[:protein] / (current_user.protein_goal || 150).to_f * 100), 100].min %>" max="100"></progress>
    </div>

    <div class="fittrack-panel rounded-2xl p-5">
      <p class="text-xs uppercase tracking-[0.2em] text-slate-400">Carbs</p>
      <div class="mt-3 flex items-end gap-2">
        <p class="text-3xl font-semibold text-slate-900"><%= @today_nutrition[:carbs].round(1) %>g</p>
        <p class="text-sm text-slate-500">/ <%= current_user.carb_goal || 250 %>g</p>
      </div>
      <progress class="progress progress-warning mt-3" value="<%= [(@today_nutrition[:carbs] / (current_user.carb_goal || 250).to_f * 100), 100].min %>" max="100"></progress>
    </div>

    <div class="fittrack-panel rounded-2xl p-5">
      <p class="text-xs uppercase tracking-[0.2em] text-slate-400">Fat</p>
      <div class="mt-3 flex items-end gap-2">
        <p class="text-3xl font-semibold text-slate-900"><%= @today_nutrition[:fat].round(1) %>g</p>
        <p class="text-sm text-slate-500">/ <%= current_user.fat_goal || 65 %>g</p>
      </div>
      <progress class="progress progress-secondary mt-3" value="<%= [(@today_nutrition[:fat] / (current_user.fat_goal || 65).to_f * 100), 100].min %>" max="100"></progress>
    </div>
  </div>

  <div class="grid grid-cols-1 gap-6 lg:grid-cols-2">
    <div class="fittrack-surface rounded-3xl">
      <div class="flex items-center justify-between border-b border-slate-200/60 px-6 py-5">
        <div>
          <h3 class="text-lg font-semibold text-slate-900">Today's workouts</h3>
          <p class="text-xs text-slate-500">Track what's scheduled for today.</p>
        </div>
        <%= link_to "View all", workouts_path, class: "text-sm font-semibold text-slate-600 hover:text-slate-900" %>
      </div>
      <div class="px-6 py-4">
        <% if @today_workouts.any? %>
          <ul class="space-y-4">
            <% @today_workouts.each do |workout| %>
              <li class="rounded-2xl border border-slate-200/60 bg-white/70 p-4">
                <%= link_to workout, class: "flex flex-wrap items-center justify-between gap-3" do %>
                  <div>
                    <p class="text-sm font-semibold text-slate-900"><%= workout.name %></p>
                    <p class="text-xs text-slate-500"><%= workout.exercises.count %> exercises · <%= workout.duration_minutes || '~30' %> min</p>
                  </div>
                  <span class="fittrack-pill <%= workout.completed? ? 'bg-emerald-100 text-emerald-700' : 'bg-amber-100 text-amber-700' %>">
                    <%= workout.completed? ? "Completed" : "Pending" %>
                  </span>
                <% end %>
              </li>
            <% end %>
          </ul>
        <% else %>
          <div class="py-10 text-center">
            <p class="text-sm text-slate-500">No workouts today.</p>
            <div class="mt-4">
              <%= link_to "Create workout", new_workout_path, class: "btn btn-primary btn-sm" %>
            </div>
          </div>
        <% end %>
      </div>
    </div>

    <div class="fittrack-surface rounded-3xl">
      <div class="flex items-center justify-between border-b border-slate-200/60 px-6 py-5">
        <div>
          <h3 class="text-lg font-semibold text-slate-900">Active goals</h3>
          <p class="text-xs text-slate-500">Progress snapshots for this cycle.</p>
        </div>
        <%= link_to "View all", goals_path, class: "text-sm font-semibold text-slate-600 hover:text-slate-900" %>
      </div>
      <div class="px-6 py-4">
        <% if @active_goals.any? %>
          <ul class="space-y-4">
            <% @active_goals.each do |goal| %>
              <li class="rounded-2xl border border-slate-200/60 bg-white/70 p-4">
                <div class="flex items-center justify-between gap-3">
                  <p class="text-sm font-semibold text-slate-900"><%= goal.description %></p>
                  <span class="fittrack-pill <%= goal.on_track? ? 'bg-emerald-100 text-emerald-700' : 'bg-amber-100 text-amber-700' %>">
                    <%= goal.progress_percentage %>%
                  </span>
                </div>
                <progress class="progress <%= goal.on_track? ? 'progress-success' : 'progress-warning' %> mt-3" value="<%= goal.progress_percentage %>" max="100"></progress>
                <p class="mt-2 text-xs text-slate-500"><%= goal.days_remaining %> days remaining</p>
              </li>
            <% end %>
          </ul>
        <% else %>
          <div class="py-10 text-center">
            <p class="text-sm text-slate-500">No active goals yet.</p>
            <div class="mt-4">
              <%= link_to "Set a goal", new_goal_path, class: "btn btn-primary btn-sm" %>
            </div>
          </div>
        <% end %>
      </div>
    </div>
  </div>

  <div class="fittrack-surface rounded-3xl">
    <div class="flex items-center justify-between border-b border-slate-200/60 px-6 py-5">
      <div>
        <h3 class="text-lg font-semibold text-slate-900">Upcoming workouts</h3>
        <p class="text-xs text-slate-500">Stay ahead with your next sessions.</p>
      </div>
      <%= link_to "View calendar", workouts_path, class: "text-sm font-semibold text-slate-600 hover:text-slate-900" %>
    </div>
    <div class="px-6 py-5">
      <% if @upcoming_workouts.any? %>
        <ul class="space-y-3">
          <% @upcoming_workouts.each do |workout| %>
            <li class="flex items-center justify-between rounded-2xl border border-slate-200/60 bg-white/70 px-4 py-3">
              <div>
                <%= link_to workout.name, workout, class: "text-sm font-semibold text-slate-900 hover:text-slate-700" %>
                <p class="text-xs text-slate-500"><%= workout.exercises.count %> exercises</p>
              </div>
              <span class="text-xs font-semibold text-slate-500"><%= workout.scheduled_date.strftime("%b %d") %></span>
            </li>
          <% end %>
        </ul>
      <% else %>
        <p class="text-sm text-slate-500 text-center py-4">No upcoming workouts scheduled.</p>
      <% end %>
    </div>
  </div>

  <div class="rounded-3xl bg-gradient-to-r from-slate-900 via-slate-800 to-slate-900 p-6 text-white shadow-lg">
    <div class="flex flex-col gap-4 md:flex-row md:items-center md:justify-between">
      <div>
        <p class="text-xs uppercase tracking-[0.2em] text-slate-300">FitTrack AI</p>
        <h3 class="text-2xl font-semibold">Ask the AI coach for today’s focus</h3>
        <p class="text-sm text-slate-300">Generate a workout or meal plan tailored to your recent progress.</p>
      </div>
      <div>
        <%= link_to ai_path, class: "btn btn-primary" do %>
          Chat with AI
        <% end %>
      </div>
    </div>
  </div>
</div>
