<div class="space-y-6">
  <div class="flex items-center justify-between">
    <div>
      <h1 class="text-2xl font-bold text-gray-900">New Goal</h1>
      <p class="text-sm text-gray-500">Define a clear target to stay motivated.</p>
    </div>
    <%= link_to "Back", goals_path, class: "text-sm font-medium text-indigo-600 hover:text-indigo-500" %>
  </div>

  <div class="rounded-lg bg-white p-6 shadow">
    <%= render "form", goal: @goal %>
  </div>
</div>
