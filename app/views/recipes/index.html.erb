<div class="space-y-6">
  <div class="flex flex-col gap-4 sm:flex-row sm:items-center sm:justify-between">
    <div>
      <h1 class="text-2xl font-bold text-gray-900">Recipes</h1>
      <p class="text-sm text-gray-500">Save your favorite meals and nutrition details.</p>
    </div>
    <div class="flex items-center gap-3">
      <%= link_to "New Recipe", new_recipe_path, class: "rounded-md bg-indigo-600 px-4 py-2 text-sm font-semibold text-white shadow-sm hover:bg-indigo-500" %>
      <%= link_to "AI Assistant", ai_path, class: "rounded-md bg-white px-4 py-2 text-sm font-semibold text-indigo-600 shadow-sm ring-1 ring-inset ring-indigo-300 hover:bg-indigo-50" %>
    </div>
  </div>

  <div class="rounded-lg bg-white p-4 shadow">
    <%= form_with url: recipes_path, method: :get, local: true, class: "flex flex-col gap-3 sm:flex-row sm:items-end" do |f| %>
      <div class="flex-1">
        <%= f.label :q, "Search", class: "block text-sm font-medium text-gray-700" %>
        <%= f.text_field :q, value: params[:q], placeholder: "e.g. Chicken bowl", class: "mt-1 block w-full rounded-md border-gray-300 shadow-sm focus:border-indigo-500 focus:ring-indigo-500 sm:text-sm" %>
      </div>
      <%= f.submit "Search", class: "rounded-md bg-indigo-600 px-4 py-2 text-sm font-semibold text-white shadow-sm hover:bg-indigo-500" %>
    <% end %>
  </div>

  <div class="grid grid-cols-1 gap-4 md:grid-cols-2">
    <% if @recipes.any? %>
      <% @recipes.each do |recipe| %>
        <div class="rounded-lg bg-white p-4 shadow">
          <div class="flex items-start justify-between">
            <div>
              <h2 class="text-lg font-semibold text-gray-900"><%= link_to recipe.name, recipe_path(recipe), class: "hover:text-indigo-600" %></h2>
              <p class="mt-1 text-sm text-gray-500"><%= recipe.description.present? ? truncate(recipe.description, length: 120) : "No description." %></p>
            </div>
            <span class="text-xs font-medium <%= recipe.ai_generated? ? 'text-indigo-600' : 'text-gray-400' %>"><%= recipe.ai_generated? ? "AI" : "Manual" %></span>
          </div>
          <div class="mt-3 flex items-center justify-between text-xs text-gray-500">
            <span><%= recipe.calories || 0 %> cal</span>
            <span><%= recipe.servings || 1 %> servings</span>
          </div>
        </div>
      <% end %>
    <% else %>
      <div class="rounded-lg bg-white p-6 text-sm text-gray-500">No recipes yet.</div>
    <% end %>
  </div>
</div>
