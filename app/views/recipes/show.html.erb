<div class="space-y-6">
  <div class="flex flex-col gap-4 sm:flex-row sm:items-start sm:justify-between">
    <div>
      <h1 class="text-2xl font-bold text-gray-900"><%= @recipe.name %></h1>
      <p class="mt-1 text-sm text-gray-500"><%= @recipe.description.present? ? @recipe.description : "No description provided." %></p>
    </div>
    <div class="flex items-center gap-2">
      <%= link_to "Edit", edit_recipe_path(@recipe), class: "rounded-md bg-white px-3 py-2 text-sm font-semibold text-gray-700 shadow-sm ring-1 ring-inset ring-gray-300 hover:bg-gray-50" %>
      <%= button_to "Delete", recipe_path(@recipe), method: :delete, data: { turbo_confirm: "Delete this recipe?" }, class: "rounded-md bg-white px-3 py-2 text-sm font-semibold text-red-600 shadow-sm ring-1 ring-inset ring-red-200 hover:bg-red-50" %>
      <%= link_to "Back", recipes_path, class: "text-sm font-medium text-indigo-600 hover:text-indigo-500" %>
    </div>
  </div>

  <% if @recipe.image_url.present? %>
    <div class="rounded-lg overflow-hidden bg-white shadow">
      <img src="<%= @recipe.image_url %>" alt="<%= @recipe.name %>" class="h-64 w-full object-cover">
    </div>
  <% end %>

  <div class="grid grid-cols-1 gap-6 lg:grid-cols-3">
    <div class="lg:col-span-2 space-y-4">
      <div class="rounded-lg bg-white p-4 shadow">
        <h2 class="text-sm font-semibold text-gray-900">Instructions</h2>
        <p class="mt-2 text-sm text-gray-700"><%= simple_format(@recipe.instructions.presence || "No instructions provided.") %></p>
      </div>
    </div>

    <div class="space-y-4">
      <div class="rounded-lg bg-white p-4 shadow">
        <h2 class="text-sm font-semibold text-gray-900">Details</h2>
        <dl class="mt-3 space-y-2 text-sm text-gray-700">
          <div class="flex items-center justify-between"><dt>Prep</dt><dd><%= @recipe.prep_time || 0 %> min</dd></div>
          <div class="flex items-center justify-between"><dt>Cook</dt><dd><%= @recipe.cook_time || 0 %> min</dd></div>
          <div class="flex items-center justify-between"><dt>Servings</dt><dd><%= @recipe.servings || 1 %></dd></div>
        </dl>
      </div>
      <div class="rounded-lg bg-white p-4 shadow">
        <h2 class="text-sm font-semibold text-gray-900">Nutrition</h2>
        <dl class="mt-3 space-y-2 text-sm text-gray-700">
          <div class="flex items-center justify-between"><dt>Calories</dt><dd><%= @recipe.calories || 0 %></dd></div>
          <div class="flex items-center justify-between"><dt>Protein</dt><dd><%= @recipe.protein || 0 %>g</dd></div>
          <div class="flex items-center justify-between"><dt>Carbs</dt><dd><%= @recipe.carbs || 0 %>g</dd></div>
          <div class="flex items-center justify-between"><dt>Fat</dt><dd><%= @recipe.fat || 0 %>g</dd></div>
        </dl>
      </div>
    </div>
  </div>
</div>
