<div class="space-y-6">
  <div class="flex flex-col gap-4 sm:flex-row sm:items-start sm:justify-between">
    <div>
      <h1 class="text-2xl font-bold text-gray-900"><%= @meal.meal_type.titleize %></h1>
      <p class="mt-1 text-sm text-gray-500"><%= @meal.date.strftime("%B %d, %Y") %> · <%= @meal.total_calories %> cal</p>
    </div>
    <div class="flex items-center gap-2">
      <%= link_to "Edit", edit_meal_path(@meal), class: "rounded-md bg-white px-3 py-2 text-sm font-semibold text-gray-700 shadow-sm ring-1 ring-inset ring-gray-300 hover:bg-gray-50" %>
      <%= button_to "Delete", meal_path(@meal), method: :delete, data: { turbo_confirm: "Delete this meal?" }, class: "rounded-md bg-white px-3 py-2 text-sm font-semibold text-red-600 shadow-sm ring-1 ring-inset ring-red-200 hover:bg-red-50" %>
      <%= link_to "Back", meals_path(date: @meal.date), class: "text-sm font-medium text-indigo-600 hover:text-indigo-500" %>
    </div>
  </div>

  <div class="grid grid-cols-1 gap-6 lg:grid-cols-3">
    <div class="lg:col-span-2 space-y-4">
      <div class="rounded-lg bg-white shadow">
        <div class="border-b border-gray-200 px-4 py-3">
          <h2 class="text-sm font-semibold text-gray-900">Food Items</h2>
        </div>
        <% if @meal_foods.any? %>
          <ul role="list" class="divide-y divide-gray-200">
            <% @meal_foods.each do |mf| %>
              <li class="p-4">
                <div class="flex items-center justify-between">
                  <div>
                    <p class="text-sm font-semibold text-gray-900"><%= mf.food.name %></p>
                    <p class="mt-1 text-xs text-gray-500"><%= mf.servings %> serving(s) · <%= mf.calories %> cal</p>
                  </div>
                  <div class="flex items-center gap-2">
                    <%= button_to "Remove", meal_meal_food_path(@meal, mf), method: :delete, data: { turbo_confirm: "Remove this food?" }, class: "text-xs font-semibold text-red-600 hover:text-red-700" %>
                  </div>
                </div>
              </li>
            <% end %>
          </ul>
        <% else %>
          <div class="p-6 text-sm text-gray-500">No food items added yet.</div>
        <% end %>
      </div>

      <% if @meal.notes.present? %>
        <div class="rounded-lg bg-white p-4 shadow">
          <h2 class="text-sm font-semibold text-gray-900">Notes</h2>
          <p class="mt-2 text-sm text-gray-700"><%= simple_format(@meal.notes) %></p>
        </div>
      <% end %>
    </div>

    <div class="space-y-4">
      <div class="rounded-lg bg-white p-4 shadow">
        <h2 class="text-sm font-semibold text-gray-900">Add Food</h2>
        <%= form_with model: [@meal, MealFood.new], local: true, class: "mt-4 space-y-3" do |f| %>
          <div>
            <%= f.label :food_id, "Food", class: "block text-sm font-medium text-gray-700" %>
            <%= f.collection_select :food_id, @foods, :id, :name, { prompt: "Select" }, class: "mt-1 block w-full rounded-md border-gray-300 shadow-sm focus:border-indigo-500 focus:ring-indigo-500 sm:text-sm" %>
          </div>
          <div>
            <%= f.label :servings, class: "block text-sm font-medium text-gray-700" %>
            <%= f.number_field :servings, step: 0.25, min: 0.25, value: 1, class: "mt-1 block w-full rounded-md border-gray-300 shadow-sm focus:border-indigo-500 focus:ring-indigo-500 sm:text-sm" %>
          </div>
          <%= f.submit "Add", class: "w-full rounded-md bg-indigo-600 px-3 py-2 text-sm font-semibold text-white shadow-sm hover:bg-indigo-500" %>
        <% end %>
        <div class="mt-4 text-xs text-gray-500">
          Can't find a food? <%= link_to "Add a new food", new_food_path, class: "text-indigo-600 hover:text-indigo-500" %>
        </div>
      </div>

      <div class="rounded-lg bg-white p-4 shadow">
        <h2 class="text-sm font-semibold text-gray-900">Nutrition</h2>
        <dl class="mt-3 space-y-2 text-sm text-gray-700">
          <div class="flex items-center justify-between"><dt>Calories</dt><dd><%= @meal.total_calories %></dd></div>
          <div class="flex items-center justify-between"><dt>Protein</dt><dd><%= @meal.total_protein %>g</dd></div>
          <div class="flex items-center justify-between"><dt>Carbs</dt><dd><%= @meal.total_carbs %>g</dd></div>
          <div class="flex items-center justify-between"><dt>Fat</dt><dd><%= @meal.total_fat %>g</dd></div>
        </dl>
      </div>
    </div>
  </div>
</div>
