<div class="space-y-6">
  <div class="flex items-center justify-between">
    <div>
      <h1 class="text-2xl font-bold text-gray-900">Log Meal</h1>
      <p class="text-sm text-gray-500">Add a meal and then attach foods.</p>
    </div>
    <%= link_to "Back", meals_path(date: @meal.date), class: "text-sm font-medium text-indigo-600 hover:text-indigo-500" %>
  </div>

  <div class="rounded-lg bg-white p-6 shadow">
    <%= render "form", meal: @meal %>
  </div>
</div>
