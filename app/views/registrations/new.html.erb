<div class="mx-auto grid min-h-[80vh] max-w-5xl items-center gap-10 lg:grid-cols-2">
  <div class="space-y-6">
    <div class="inline-flex items-center gap-2 rounded-full bg-white/70 px-4 py-2 text-xs font-semibold uppercase tracking-[0.2em] text-slate-500 shadow">
      <span class="h-2 w-2 rounded-full bg-rose-400"></span>
      Build your plan
    </div>
    <h1 class="fittrack-display text-4xl text-slate-900 sm:text-5xl">Create your FitTrack AI account</h1>
    <p class="text-base text-slate-600">One place for training, nutrition, and progress. Get tailored recommendations as soon as you sign in.</p>
    <div class="flex items-center gap-3 text-sm text-slate-500">
      <span class="inline-flex items-center gap-2">
        <span class="h-2 w-2 rounded-full bg-emerald-400"></span>
        Personalized plans
      </span>
      <span class="inline-flex items-center gap-2">
        <span class="h-2 w-2 rounded-full bg-sky-400"></span>
        Meal guidance
      </span>
    </div>
  </div>

  <div class="fittrack-auth-card rounded-3xl p-8">
    <div class="mb-6">
      <h2 class="text-2xl font-semibold text-slate-900">Get started</h2>
      <p class="text-sm text-slate-500">
        Already have an account?
        <%= link_to "Sign in", new_session_path, class: "font-semibold text-slate-900 underline decoration-rose-400 decoration-2 underline-offset-4" %>
      </p>
    </div>
    <%= form_with model: @user, url: registration_path, class: "space-y-5" do |f| %>
      <% if @user.errors.any? %>
        <div class="alert alert-error shadow-sm">
          <svg class="h-5 w-5" viewBox="0 0 20 20" fill="currentColor">
            <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zM8.28 7.22a.75.75 0 00-1.06 1.06L8.94 10l-1.72 1.72a.75.75 0 101.06 1.06L10 11.06l1.72 1.72a.75.75 0 101.06-1.06L11.06 10l1.72-1.72a.75.75 0 00-1.06-1.06L10 8.94 8.28 7.22z" clip-rule="evenodd" />
          </svg>
          <div>
            <h3 class="text-sm font-semibold"><%= pluralize(@user.errors.count, "error") %> blocked this account:</h3>
            <ul class="mt-1 list-disc space-y-1 pl-5 text-sm">
              <% @user.errors.full_messages.each do |message| %>
                <li><%= message %></li>
              <% end %>
            </ul>
          </div>
        </div>
      <% end %>

      <div class="form-control">
        <%= f.label :email_address, "Email address", class: "label text-sm font-semibold text-slate-700" %>
        <%= f.email_field :email_address, required: true, autofocus: true, autocomplete: "email", class: "fittrack-input input input-bordered w-full" %>
      </div>

      <div class="form-control">
        <%= f.label :password, class: "label text-sm font-semibold text-slate-700" %>
        <%= f.password_field :password, required: true, autocomplete: "new-password", class: "fittrack-input input input-bordered w-full" %>
        <p class="mt-1 text-xs text-slate-500">Must be at least 8 characters</p>
      </div>

      <div class="form-control">
        <%= f.label :password_confirmation, "Confirm password", class: "label text-sm font-semibold text-slate-700" %>
        <%= f.password_field :password_confirmation, required: true, autocomplete: "new-password", class: "fittrack-input input input-bordered w-full" %>
      </div>

      <div>
        <%= f.submit "Create account", class: "btn btn-primary w-full" %>
      </div>
    <% end %>
  </div>
</div>
