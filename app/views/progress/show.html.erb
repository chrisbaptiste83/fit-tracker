<div class="space-y-6">
  <div class="flex flex-col gap-4 sm:flex-row sm:items-start sm:justify-between">
    <div>
      <h1 class="text-2xl font-bold text-gray-900"><%= @progress_log.date.strftime("%B %d, %Y") %></h1>
      <p class="text-sm text-gray-500">Progress snapshot.</p>
    </div>
    <div class="flex items-center gap-2">
      <%= link_to "Edit", edit_progress_path(@progress_log), class: "rounded-md bg-white px-3 py-2 text-sm font-semibold text-gray-700 shadow-sm ring-1 ring-inset ring-gray-300 hover:bg-gray-50" %>
      <%= button_to "Delete", progress_path(@progress_log), method: :delete, data: { turbo_confirm: "Delete this log?" }, class: "rounded-md bg-white px-3 py-2 text-sm font-semibold text-red-600 shadow-sm ring-1 ring-inset ring-red-200 hover:bg-red-50" %>
      <%= link_to "Back", progress_index_path, class: "text-sm font-medium text-indigo-600 hover:text-indigo-500" %>
    </div>
  </div>

  <div class="grid grid-cols-1 gap-6 lg:grid-cols-3">
    <div class="lg:col-span-2 space-y-4">
      <div class="rounded-lg bg-white p-6 shadow">
        <dl class="grid grid-cols-1 gap-4 sm:grid-cols-2">
          <div>
            <dt class="text-sm font-medium text-gray-500">Weight</dt>
            <dd class="mt-1 text-sm text-gray-900"><%= @progress_log.weight || "-" %></dd>
          </div>
          <div>
            <dt class="text-sm font-medium text-gray-500">Body Fat %</dt>
            <dd class="mt-1 text-sm text-gray-900"><%= @progress_log.body_fat_percentage || "-" %></dd>
          </div>
          <div>
            <dt class="text-sm font-medium text-gray-500">Chest</dt>
            <dd class="mt-1 text-sm text-gray-900"><%= @progress_log.chest || "-" %></dd>
          </div>
          <div>
            <dt class="text-sm font-medium text-gray-500">Waist</dt>
            <dd class="mt-1 text-sm text-gray-900"><%= @progress_log.waist || "-" %></dd>
          </div>
          <div>
            <dt class="text-sm font-medium text-gray-500">Hips</dt>
            <dd class="mt-1 text-sm text-gray-900"><%= @progress_log.hips || "-" %></dd>
          </div>
          <div>
            <dt class="text-sm font-medium text-gray-500">Arms</dt>
            <dd class="mt-1 text-sm text-gray-900"><%= @progress_log.arms || "-" %></dd>
          </div>
          <div>
            <dt class="text-sm font-medium text-gray-500">Thighs</dt>
            <dd class="mt-1 text-sm text-gray-900"><%= @progress_log.thighs || "-" %></dd>
          </div>
        </dl>
      </div>

      <% if @progress_log.notes.present? %>
        <div class="rounded-lg bg-white p-4 shadow">
          <h2 class="text-sm font-semibold text-gray-900">Notes</h2>
          <p class="mt-2 text-sm text-gray-700"><%= simple_format(@progress_log.notes) %></p>
        </div>
      <% end %>
    </div>

    <div class="space-y-4">
      <% if @progress_log.photo.attached? %>
        <div class="rounded-lg bg-white p-4 shadow">
          <h2 class="text-sm font-semibold text-gray-900">Photo</h2>
          <div class="mt-3">
            <%= image_tag @progress_log.photo, class: "w-full rounded" %>
          </div>
        </div>
      <% end %>
      <div class="rounded-lg bg-white p-4 shadow">
        <h2 class="text-sm font-semibold text-gray-900">BMI</h2>
        <p class="mt-2 text-sm text-gray-700"><%= @progress_log.bmi || "-" %></p>
      </div>
    </div>
  </div>
</div>
