<div>
  <h2 class="text-sm font-semibold text-gray-900">Weight Trend (last 90 days)</h2>
  <% if @weight_data.any? %>
    <div class="mt-3 grid grid-cols-2 gap-2 sm:grid-cols-4">
      <% @weight_data.last(8).each do |date, weight| %>
        <div class="rounded bg-gray-100 px-3 py-2 text-center">
          <div class="text-xs text-gray-500"><%= date.strftime("%b %d") %></div>
          <div class="text-sm font-semibold text-gray-900"><%= weight %></div>
        </div>
      <% end %>
    </div>
  <% else %>
    <p class="mt-2 text-sm text-gray-500">No weight data yet.</p>
  <% end %>
</div>
